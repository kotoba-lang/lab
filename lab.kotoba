(ns kotoba.lab.site)

(def lab-ui
  {:app/title "kotoba-lab"
   :app/subtitle "Research workbench for safe, replayable Kotoba analysis"
   :app/status "prototype"
   :app/repo "kotoba-lang/lab"
   :app/adr "docs/adr/ADR-kotoba-lab-research-notebook.md"

   :lab/notebook
   {:lab/notebook-id "did:kotoba:lab:solar-degradation-demo"
    :lab/title "Solar panel degradation study"
    :lab/updated "2026-07-01"
    :lab/replay-status "replayable"
    :lab/run-id "r-20260701-001"
    :lab/replay-fingerprint "bafy-replay-initial"
    :lab/runtime "kotoba-wasm/safe"
    :lab/compiler "kotoba wasm safe-build"
    :lab/storage "Datoms + CID artifacts"
    :lab/environment-lock
    {:env/schema "kotoba-lab-notebook/v1"
     :env/runtime "kotoba-wasm-safe"
     :env/runtime-version "shim-0.2.0"
     :env/llm-provider "kotoba-research-assistant"
     :env/llm-provider-version "shim-0.1.0"
     :env/verification-contract "src/kotoba/lab/verification.kotoba"
     :env/verification-check "test/kotoba/lab/verification_conformance.kotoba"
     :env/browser-runner "scripts/verify-lab.js"
     :env/status :locked}
    :lab/review-snapshot
    {:snapshot/id "snapshot-initial"
     :snapshot/status :ready
     :snapshot/replay-fingerprint "bafy-replay-initial"
     :snapshot/environment "kotoba-lab-notebook/v1 / kotoba-wasm-safe shim-0.2.0 / kotoba-research-assistant shim-0.1.0"
     :snapshot/coverage "initial M4 review baseline"}
    :lab/inference
    {:inference/engine :kotoba-local
     :inference/policy "infer minimal cell capabilities from Kotoba source and block kind"
     :inference/llm "llm-infer cells are represented as Kotoba source with explicit :llm-infer capability"
     :inference/replay "dependency and grant checks are evaluated before marking a run clean"}
    :lab/runtime-adapters
    [{:adapter/id :kotoba-wasm-safe
      :adapter/status :shim-active
      :adapter/contract "source -> safe-build-compatible compile API -> runtime API -> artifact evidence"}
     {:adapter/id :local-deterministic
      :adapter/status :active
      :adapter/contract "browser-local deterministic fallback with source/policy/wasm/output CIDs"}]
    :lab/llm-providers
    [{:provider/id :kotoba-research-assistant
      :provider/status :shim-active
      :provider/capability :llm-infer
      :provider/contract "llm-infer cell -> provider adapter -> deterministic draft artifact -> evidence"}]
    :lab/maturity
    {:maturity/current :m3
     :maturity/target :m4
     :maturity/coverage "computed in browser from cells, artifacts, rich outputs, review snapshots, run-all evidence, runtime adapter readiness, environment lock, replay ledger, persistence support, accessibility, and CI browser verification"
     :maturity/next "replace runtime-shim.js and llm-provider-shim.js with real kotoba-wasm safe-build/runtime and provider adapters"}
    :lab/verification
    {:verification/status :ci-active
     :verification/contract "src/kotoba/lab/verification.kotoba"
     :verification/check "test/kotoba/lab/verification_conformance.kotoba"
     :verification/browser-runner "scripts/verify-lab.js"
     :verification/coverage "runtime adapter, llm provider, environment lock, accessibility, persistence, evidence, maturity, and layout overflow"}
    :lab/cells
    [{:cell/id "c-001"
      :cell/kind :query
      :cell/title "Bind module telemetry"
      :cell/status :succeeded
      :cell/policy [:graph-read :artifact-read]
      :cell/source "(defn modules [graph]\n  (kqe-query graph :module/degradation))"
      :cell/depends-on []
      :cell/output "1,248 modules / 36 months / 9 sites"
      :cell/output-kind :table
      :cell/output-media-type "application/vnd.apache.arrow.file"
      :cell/source-cid "bafy-source-c001"
      :cell/wasm-cid "bafy-wasm-c001"
      :cell/output-cids ["bafy-output-c001"]}
     {:cell/id "c-002"
      :cell/kind :kotoba
      :cell/title "Normalize observations"
      :cell/status :succeeded
      :cell/policy [:artifact-read :artifact-write]
      :cell/source "(defn normalize [rows]\n  (table/select rows [:site :month :loss-pct :temperature]))"
      :cell/depends-on ["c-001"]
      :cell/output "table: normalized-observations.arrow"
      :cell/output-kind :table
      :cell/output-media-type "application/vnd.apache.arrow.file"
      :cell/source-cid "bafy-source-c002"
      :cell/wasm-cid "bafy-wasm-c002"
      :cell/output-cids ["bafy-output-c002"]}
     {:cell/id "c-003"
      :cell/kind :table
      :cell/title "Group by site and month"
      :cell/status :succeeded
      :cell/policy [:artifact-read :artifact-write]
      :cell/source "{:group-by [:site :month]\n :measures [{:name :avg-loss :op :mean :column :loss-pct}]}"
      :cell/depends-on ["c-002"]
      :cell/output "108 grouped rows"
      :cell/output-kind :table
      :cell/output-media-type "application/vnd.apache.arrow.file"
      :cell/source-cid "bafy-source-c003"
      :cell/wasm-cid "bafy-wasm-c003"
      :cell/output-cids ["bafy-output-c003"]}
     {:cell/id "c-004"
      :cell/kind :viz
      :cell/title "Degradation curve"
      :cell/status :ready
      :cell/policy [:artifact-read :artifact-write]
      :cell/source "{:mark :line\n :x :month\n :y :avg-loss\n :color :site\n :facet :temperature-band}"
      :cell/depends-on ["c-003"]
      :cell/output "figure: degradation-curve.svg"
      :cell/output-kind :figure
      :cell/output-media-type "image/svg+xml"}
     {:cell/id "c-005"
      :cell/kind :markdown
      :cell/title "Claim"
      :cell/status :draft
      :cell/policy []
      :cell/source "Sites with sustained heat exposure show earlier degradation acceleration."
      :cell/depends-on ["c-003" "c-004"]
      :cell/output "claim linked to run evidence"}]

    :lab/artifacts
    [{:artifact/name "raw-module-telemetry"
      :artifact/kind :dataset
      :artifact/cid "bafy-lab-telemetry"
      :artifact/media-type "text/csv"
      :artifact/size "18.4 MB"}
     {:artifact/name "normalized-observations"
      :artifact/kind :table
      :artifact/cid "bafy-lab-normalized"
      :artifact/media-type "application/vnd.apache.arrow.file"
      :artifact/size "4.2 MB"}
     {:artifact/name "degradation-curve"
      :artifact/kind :figure
      :artifact/cid "bafy-lab-curve"
      :artifact/media-type "image/svg+xml"
      :artifact/size "74 KB"}
     {:artifact/name "run-evidence"
      :artifact/kind :evidence
      :artifact/cid "bafy-lab-evidence"
      :artifact/media-type "application/edn"
      :artifact/size "12 KB"}]

    :lab/runs
    [{:run/id "r-20260701-001"
      :run/cell-id "c-003"
      :run/status :succeeded
      :run/replay :clean
      :run/source-cid "bafy-source-c003"
      :run/policy-cid "bafy-policy-c003"
      :run/wasm-cid "bafy-wasm-c003"
      :run/output-cid "bafy-output-c003"
      :run/runtime "kotoba-wasm-safe"
      :run/provider "none"
      :run/timing-ms 184}
     {:run/id "r-20260701-000"
      :run/cell-id "c-002"
      :run/status :succeeded
      :run/replay :clean
      :run/source-cid "bafy-source-c002"
      :run/policy-cid "bafy-policy-c002"
      :run/wasm-cid "bafy-wasm-c002"
      :run/output-cid "bafy-output-c002"
      :run/runtime "kotoba-wasm-safe"
      :run/provider "none"
      :run/timing-ms 141}]

    :lab/evidence
    {:evidence/source-cid "bafy-source-c003"
     :evidence/policy-cid "bafy-policy-c003"
     :evidence/wasm-cid "bafy-wasm-c003"
     :evidence/input-cids ["bafy-lab-normalized"]
     :evidence/output-cids ["bafy-lab-curve" "bafy-lab-evidence"]
     :evidence/capabilities-used [:artifact-read :artifact-write]
     :evidence/replay "clean"
     :evidence/replay-fingerprint "bafy-replay-initial"
     :evidence/timing-ms 184
     :evidence/host "local-first lab host"}}})
