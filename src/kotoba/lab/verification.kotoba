(ns kotoba.lab.verification
  (:export [environment-locked? review-snapshot-ready? maturity-ready?]))

(defn environment-locked?
  [environment [:record :kotoba.lab/environment
                [[:schema :string]
                 [:runtime :string]
                 [:runtime-version :string]
                 [:llm-provider :string]
                 [:llm-provider-version :string]]]]
  :bool
  (if (and
    (string=? "kotoba-lab-notebook/v1"
      (record-get [:record :kotoba.lab/environment
                   [[:schema :string]
                    [:runtime :string]
                    [:runtime-version :string]
                    [:llm-provider :string]
                    [:llm-provider-version :string]]]
                  environment :schema))
    (string=? "kotoba-wasm-safe"
      (record-get [:record :kotoba.lab/environment
                   [[:schema :string]
                    [:runtime :string]
                    [:runtime-version :string]
                    [:llm-provider :string]
                    [:llm-provider-version :string]]]
                  environment :runtime))
    (string=? "shim-0.2.0"
      (record-get [:record :kotoba.lab/environment
                   [[:schema :string]
                    [:runtime :string]
                    [:runtime-version :string]
                    [:llm-provider :string]
                    [:llm-provider-version :string]]]
                  environment :runtime-version))
    (string=? "kotoba-research-assistant"
      (record-get [:record :kotoba.lab/environment
                   [[:schema :string]
                    [:runtime :string]
                    [:runtime-version :string]
                    [:llm-provider :string]
                    [:llm-provider-version :string]]]
                  environment :llm-provider))
    (string=? "shim-0.1.0"
      (record-get [:record :kotoba.lab/environment
                   [[:schema :string]
                    [:runtime :string]
                    [:runtime-version :string]
                    [:llm-provider :string]
                    [:llm-provider-version :string]]]
                  environment :llm-provider-version)))
    true
    false))

(defn review-snapshot-ready?
  [snapshot [:record :kotoba.lab/review-snapshot
             [[:status :keyword]
              [:id :string]
              [:replay-fingerprint :string]
              [:environment :string]
              [:coverage :string]]]]
  :bool
  (if (= :ready
         (record-get [:record :kotoba.lab/review-snapshot
                      [[:status :keyword]
                       [:id :string]
                       [:replay-fingerprint :string]
                       [:environment :string]
                       [:coverage :string]]]
                     snapshot :status))
    true
    false))

(defn maturity-ready?
  [report [:record :kotoba.lab/maturity-report
           [[:coverage :i64]
            [:maturity :keyword]
            [:covered [:set :keyword]]]]]
  :bool
  (let [covered
        (record-get [:record :kotoba.lab/maturity-report
                     [[:coverage :i64]
                      [:maturity :keyword]
                      [:covered [:set :keyword]]]]
                    report :covered)]
    (if (and
      (>= (record-get [:record :kotoba.lab/maturity-report
                       [[:coverage :i64]
                        [:maturity :keyword]
                        [:covered [:set :keyword]]]]
                      report :coverage)
          70)
      (= :m4
         (record-get [:record :kotoba.lab/maturity-report
                      [[:coverage :i64]
                       [:maturity :keyword]
                       [:covered [:set :keyword]]]]
                     report :maturity))
      (if (typed-set-contains [:set :keyword] covered :notebook-ui) 1 0)
      (if (typed-set-contains [:set :keyword] covered :manifest-contract) 1 0)
      (if (typed-set-contains [:set :keyword] covered :local-execution) 1 0)
      (if (typed-set-contains [:set :keyword] covered :runtime-adapter) 1 0)
      (if (typed-set-contains [:set :keyword] covered :environment-lock) 1 0)
      (if (typed-set-contains [:set :keyword] covered :evidence) 1 0)
      (if (typed-set-contains [:set :keyword] covered :llm-workflow) 1 0)
      (if (typed-set-contains [:set :keyword] covered :rich-outputs) 1 0)
      (if (typed-set-contains [:set :keyword] covered :persistence) 1 0)
      (if (typed-set-contains [:set :keyword] covered :review-snapshot) 1 0)
      (if (typed-set-contains [:set :keyword] covered :contract-verification) 1 0)
      (if (typed-set-contains [:set :keyword] covered :accessibility) 1 0)
      (if (typed-set-contains [:set :keyword] covered :replay-ledger) 1 0)
      (if (typed-set-contains [:set :keyword] covered :browser-verification) 1 0))
      true
      false)))
