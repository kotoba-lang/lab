(ns kotoba.lab.verification-conformance
  (:require [kotoba.lab.verification :as verification])
  (:export [main]))

(defn full-coverage
  []
  [:set :keyword]
  (typed-set [:set :keyword]
    :notebook-ui
    :manifest-contract
    :local-execution
    :runtime-adapter
    :environment-lock
    :evidence
    :llm-workflow
    :rich-outputs
    :persistence
    :review-snapshot
    :contract-verification
    :accessibility
    :replay-ledger
    :browser-verification))

(defn environment
  [runtime :string]
  [:record :kotoba.lab/environment
   [[:schema :string]
    [:runtime :string]
    [:runtime-version :string]
    [:llm-provider :string]
    [:llm-provider-version :string]]]
  (record [:record :kotoba.lab/environment
           [[:schema :string]
            [:runtime :string]
            [:runtime-version :string]
            [:llm-provider :string]
            [:llm-provider-version :string]]]
          "kotoba-lab-notebook/v1"
          runtime
          "shim-0.2.0"
          "kotoba-research-assistant"
          "shim-0.1.0"))

(defn maturity-report
  [coverage :i64]
  [:record :kotoba.lab/maturity-report
   [[:coverage :i64]
    [:maturity :keyword]
    [:covered [:set :keyword]]]]
  (record [:record :kotoba.lab/maturity-report
           [[:coverage :i64]
            [:maturity :keyword]
            [:covered [:set :keyword]]]]
          coverage :m4 (full-coverage)))

(defn main
  []
  (if (and
        (verification/environment-locked? (environment "kotoba-wasm-safe"))
        (if (verification/environment-locked? (environment "ambient-js")) false true)
        (verification/review-snapshot-ready?
          (record [:record :kotoba.lab/review-snapshot
                   [[:status :keyword]
                    [:id :string]
                    [:replay-fingerprint :string]
                    [:environment :string]
                    [:coverage :string]]]
                  :ready "review-1" "sha256:fixture" "locked" "complete"))
        (verification/maturity-ready? (maturity-report 70))
        (if (verification/maturity-ready? (maturity-report 69)) false true))
    42
    0))
